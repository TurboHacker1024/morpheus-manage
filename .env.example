# Optional preconfigured homeserver used to prefill login or enable fallback-token mode
# SYNAPSE_BASE_URL=https://your-synapse-domain.example

# Optional preconfigured fallback admin access token
# SYNAPSE_ADMIN_TOKEN=replace_with_admin_token

# Optional homeserver name override (defaults to the selected homeserver host)
# SYNAPSE_SERVER_NAME=your-synapse-domain.example

# Local port for this UI
PORT=4173

# Optional tuning
# ACTION_LOG_MAX_ENTRIES=5000
# JSON_BODY_LIMIT=12mb
# MAX_AVATAR_UPLOAD_BYTES=5242880
# MEDIA_QUERY_MAX_LIMIT=500
